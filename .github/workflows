name: Build and Push Multiple Docker Images

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v2

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v1

      - name: Login to Docker Hub
        uses: docker/login-action@v1 
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Build and push grafana Docker image
        uses: docker/build-push-action@v2 
        with:
          context: .
          file: ./Dockerfile.grafana
          push: true
          tags: ${{ secrets.DOCKER_USERNAME }}/my-grafana:${{ github.sha }}

      - name: Save grafana Docker image as file
        run: |
          docker save ${{ secrets.DOCKER_USERNAME }}/my-grafana:${{ github.sha }} | gzip > my-grafana-${{ github.sha }}.tar.gz

      - name: Build and push app2 Docker image
        uses: docker/build-push-action@v2 
        with:
          context: .
          file: ./Dockerfile.app2
          push: true
          tags: ${{ secrets.DOCKER_USERNAME }}/my-app2:${{ github.sha }}

      - name: Save app2 Docker image as file
        run: |
          docker save ${{ secrets.DOCKER_USERNAME }}/my-app2:${{ github.sha }} | gzip > my-app2-${{ github.sha }}.tar.gz

      - name: Upload artifacts (saved images)
        uses: actions/upload-artifact@v2 
        with:
          name: docker-images-${{ github.sha }}
          path: |
            my-grafana-${{ github.sha }}.tar.gz
            my-app2-${{ github.sha }}.tar.gz

